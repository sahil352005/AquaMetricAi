# AquaMetric AI Environment Configuration
# Get your FREE Groq API key: https://console.groq.com/keys
# No OpenAI key needed - uses free Grok model!

GROQ_API_KEY=your_groq_api_key_here
# OPENAI_API_KEY=sk-your_openai_key_here  # Optional, for OpenAI fallback

# Optional settings
OPENAI_MODEL=gpt-4o-mini
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
FLASK_ENV=development
FLASK_DEBUG=True
